---
interface Props {
  title: string
  description: string
  canonicalUrl: string
  ogTitle?: string
  ogDescription?: string
  activePage: 'home' | 'works' | 'spark'
}

const {
  title,
  description,
  canonicalUrl,
  ogTitle,
  ogDescription,
  activePage,
} = Astro.props
---

<!DOCTYPE html>
<html lang="en" data-theme="auto">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="Joshua McManus" />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://www.jajm2006.uk/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:       #0d0d0f;
      --ink-2:     #141418;
      --ink-3:     #1c1c22;
      --ink-4:     #252530;
      --rule:      #2e2e3a;
      --rule-2:    #3d3d50;
      --dim:       #5a5a72;
      --muted:     #8585a0;
      --body:      #c8c8d8;
      --head:      #e8e8f0;
      --bright:    #f4f4f8;
      --accent:    #a89f6e;
      --accent-2:  #c4b98a;
      --accent-dim:#3a3520;
    }

    [data-theme="light"] {
      --ink:       #f5f0e8;
      --ink-2:     #ede8de;
      --ink-3:     #e4ddd2;
      --ink-4:     #d8d0c3;
      --rule:      #c8bfaf;
      --rule-2:    #b0a590;
      --dim:       #7a6e5a;
      --muted:     #5a5040;
      --body:      #3a3020;
      --head:      #1a1208;
      --bright:    #0d0800;
      --accent:    #7a6e3a;
      --accent-2:  #5a5020;
      --accent-dim:#e8e0c0;
    }

    html { scroll-behavior: smooth; font-size: 17px; }

    body {
      background: var(--ink);
      color: var(--body);
      font-family: 'EB Garamond', Georgia, serif;
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
      transition: background .3s, color .3s;
    }

    h1, h2, h3, h4 { color: var(--head); font-family: 'EB Garamond', serif; font-weight: 400; line-height: 1.25; }
    p { margin-bottom: 1.1em; max-width: 66ch; }
    a { color: var(--accent-2); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color .2s, color .2s; }
    a:hover { color: var(--bright); border-bottom-color: var(--accent); }
    strong { color: var(--head); font-weight: 500; }
    em { font-style: italic; }

    .mono { font-family: 'JetBrains Mono', monospace; font-size: .78em; font-weight: 300; letter-spacing: .02em; }
    .label { font-family: 'JetBrains Mono', monospace; font-size: .68em; font-weight: 400; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); }
    .rule-h { border: none; border-top: 1px solid var(--rule); margin: 2.5rem 0; }
    .container { max-width: 860px; margin: 0 auto; padding: 0 2rem; }

    /* ── NAV ── */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: var(--ink-2);
      border-bottom: 1px solid var(--rule);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transition: background .3s;
    }
    .nav-inner {
      max-width: 860px; margin: 0 auto; padding: 0 2rem;
      display: flex; align-items: center; justify-content: space-between;
      height: 56px;
    }
    .nav-logo {
      font-family: 'JetBrains Mono', monospace; font-size: .78em; font-weight: 500;
      letter-spacing: .08em; color: var(--accent-2); border-bottom: none; flex-shrink: 0;
    }
    .nav-logo:hover { color: var(--bright); border-bottom: none; }
    .nav-links { display: flex; align-items: center; gap: 1.5rem; }
    .nav-links a {
      font-family: 'JetBrains Mono', monospace; font-size: .68em;
      letter-spacing: .1em; text-transform: uppercase;
      color: var(--muted); border-bottom: none; transition: color .2s; white-space: nowrap;
    }
    .nav-links a:hover { color: var(--bright); border-bottom: none; }
    .nav-links a.active { color: var(--accent-2); }
    .theme-toggle {
      background: none; border: 1px solid var(--rule-2); border-radius: 4px;
      cursor: pointer; font-size: .85rem; padding: .3em .55em;
      color: var(--muted); transition: color .2s, border-color .2s; line-height: 1; flex-shrink: 0;
    }
    .theme-toggle:hover { color: var(--bright); border-color: var(--accent); }
    .nav-hamburger {
      display: none; background: none; border: none; cursor: pointer;
      flex-direction: column; gap: 5px; padding: 4px;
    }
    .nav-hamburger span {
      display: block; width: 22px; height: 2px;
      background: var(--muted); border-radius: 2px;
      transition: transform .25s, opacity .25s;
    }
    .nav-drawer {
      display: none; flex-direction: column;
      background: var(--ink-2); border-bottom: 1px solid var(--rule);
      padding: 1rem 2rem 1.25rem; gap: .9rem; transition: background .3s;
    }
    .nav-drawer a {
      font-family: 'JetBrains Mono', monospace; font-size: .72em;
      letter-spacing: .1em; text-transform: uppercase; color: var(--muted); border-bottom: none;
    }
    .nav-drawer a:hover { color: var(--bright); }
    .nav-drawer.open { display: flex; }
    .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-hamburger.open span:nth-child(2) { opacity: 0; }
    .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* ── HERO ── */
    .hero-section {
      padding: 6rem 0 5rem; border-bottom: 1px solid var(--rule);
      position: relative; overflow: hidden;
    }
    .hero-grid {
      position: absolute; inset: 0; pointer-events: none; opacity: .04;
      background-image: linear-gradient(var(--accent) 1px, transparent 1px), linear-gradient(90deg, var(--accent) 1px, transparent 1px);
      background-size: 60px 60px;
    }
    .hero-eyebrow { margin-bottom: 1.5rem; display: flex; align-items: center; gap: 1rem; }
    .hero-eyebrow::after { content: ''; flex: 1; max-width: 120px; height: 1px; background: var(--accent); opacity: .5; }
    .hero-title {
      font-size: clamp(2.4rem, 7vw, 4.5rem); font-weight: 400; line-height: 1.1;
      letter-spacing: -.01em; color: var(--bright); margin-bottom: .75rem;
    }
    .hero-title em { color: var(--accent-2); font-style: italic; }
    .hero-subtitle {
      font-size: clamp(1rem, 2.5vw, 1.3rem); color: var(--muted);
      margin-bottom: 2.5rem; font-style: italic; max-width: 54ch;
    }
    .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

    /* ── BUTTONS ── */
    .btn {
      font-family: 'JetBrains Mono', monospace; font-size: .72em; letter-spacing: .08em;
      text-transform: uppercase; padding: .7em 1.4em;
      border: 1px solid var(--rule-2); color: var(--body);
      border-radius: 2px; transition: background .2s, color .2s, border-color .2s;
      cursor: pointer; display: inline-block;
    }
    .btn:hover { background: var(--ink-4); color: var(--bright); border-color: var(--accent); border-bottom: 1px solid var(--accent); }
    .btn-accent { border-color: var(--accent); color: var(--accent-2); }
    .btn-accent:hover { background: var(--accent-dim); color: var(--bright); border-bottom: 1px solid var(--accent); }

    /* ── SECTIONS ── */
    section { padding: 4.5rem 0; border-bottom: 1px solid var(--rule); }
    section:last-of-type { border-bottom: none; }
    .section-header { display: flex; align-items: baseline; gap: 1.25rem; margin-bottom: 3rem; flex-wrap: wrap; }
    .section-num { font-family: 'JetBrains Mono', monospace; font-size: .7em; color: var(--accent); }
    .section-title { font-size: clamp(1.4rem, 3vw, 1.7rem); letter-spacing: -.01em; }

    /* ── FOOTER ── */
    footer { padding: 4rem 0 3rem; }
    .footer-base {
      margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--rule);
      display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: .5rem;
      font-family: 'JetBrains Mono', monospace; font-size: .64em; color: var(--dim);
    }

    /* ── SCROLL FADE ── */
    .fade-in { opacity: 0; transform: translateY(16px); transition: opacity .5s ease, transform .5s ease; }
    .fade-in.visible { opacity: 1; transform: none; }

    /* ── RESPONSIVE: tablet ── */
    @media (max-width: 720px) {
      .container { padding: 0 1.25rem; }
      .nav-inner { padding: 0 1.25rem; }
      .nav-links { display: none; }
      .nav-hamburger { display: flex; }
      .nav-drawer { padding: 1rem 1.25rem 1.25rem; }
      .hero-section { padding: 4rem 0 3.5rem; }
      section { padding: 3.5rem 0; }
    }

    /* ── RESPONSIVE: phone ── */
    @media (max-width: 480px) {
      html { font-size: 15px; }
      .container { padding: 0 1rem; }
      .nav-inner { padding: 0 1rem; height: 52px; }
      .nav-drawer { padding: 1rem 1rem 1.25rem; }
      .hero-section { padding: 3rem 0 2.5rem; }
      .hero-title { font-size: 2.2rem; }
      .hero-subtitle { font-size: .95rem; }
      .hero-cta { flex-direction: column; align-items: flex-start; }
      .btn { width: 100%; text-align: center; }
      section { padding: 2.75rem 0; }
      .section-header { margin-bottom: 2rem; }
    }
  </style>
</head>
<body>

  <!-- ── NAV ── -->
  <nav aria-label="Primary navigation">
    <div class="nav-inner">
      <a href="/" class="nav-logo mono">jajm2006.uk</a>
      <div class="nav-links">
        <a href="/" class={activePage === 'home' ? 'active' : ''}>Home</a>
        <a href="/works/" class={activePage === 'works' ? 'active' : ''}>Works</a>
        <a href="/spark/" class={activePage === 'spark' ? 'active' : ''}>SPARK</a>
        <button class="theme-toggle" aria-label="Toggle light/dark theme" onclick="toggleTheme()">☀︎</button>
      </div>
      <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false" onclick="toggleMenu(this)">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="nav-drawer" id="nav-drawer">
      <a href="/"       onclick="closeMenu()">Home</a>
      <a href="/works/" onclick="closeMenu()">Works</a>
      <a href="/spark/" onclick="closeMenu()">SPARK</a>
      <button class="theme-toggle" style="align-self:flex-start;margin-top:.25rem" aria-label="Toggle theme" onclick="toggleTheme()">☀︎</button>
    </div>
  </nav>

  <!-- ── PAGE CONTENT ── -->
  <slot />

  <!-- ── FOOTER BASE ── -->
  <div class="footer-base-wrap">
    <slot name="footer" />
  </div>

  <script>
    // ── THEME ──
    const root = document.documentElement;
    const toggleBtns = document.querySelectorAll('.theme-toggle');
    function getSystemTheme() { return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'; }
    function applyTheme(theme) {
      root.setAttribute('data-theme', theme);
      const icon = theme === 'dark' ? '☀︎' : '☽';
      toggleBtns.forEach(b => b.textContent = icon);
      localStorage.setItem('theme', theme);
    }
    function toggleTheme() {
      applyTheme(root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
    }
    const saved = localStorage.getItem('theme');
    applyTheme(saved || getSystemTheme());
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
      if (!localStorage.getItem('theme')) applyTheme(e.matches ? 'dark' : 'light');
    });

    // ── HAMBURGER ──
    function toggleMenu(btn) {
      const drawer = document.getElementById('nav-drawer');
      const open = drawer.classList.toggle('open');
      btn.classList.toggle('open', open);
      btn.setAttribute('aria-expanded', open);
    }
    function closeMenu() {
      const drawer = document.getElementById('nav-drawer');
      const btn = document.querySelector('.nav-hamburger');
      drawer.classList.remove('open');
      btn.classList.remove('open');
      btn.setAttribute('aria-expanded', false);
    }

    // ── SCROLL FADE ──
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.06 });
    document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
  </script>

</body>
</html>
